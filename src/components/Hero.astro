---
// src/components/Hero.astro
---

---
const githubUrl = import.meta.env.PUBLIC_GITHUB_URL || 'https://github.com';
---


<section class="hero">
  <div class="hero__content">
    <span class="hero__eyebrow">Cloud Security • AI Security • Kubernetes</span>

    <h1>
      Building practical
      <span class="gradient">security tooling</span>
      for the cloud.
    </h1>

    <p class="hero__description">
      I'm Steven R, a Cloud Security Architect focused on cloud-native
      security, AI systems, Kubernetes, and open-source engineering. I enjoy
      building tools that help security teams automate detection, strengthen
      cloud posture, and better understand emerging AI risks.
    </p>

    <div class="hero__actions">
      <a href="/projects" class="btn btn-primary">
        View Projects
      </a>

      <a
        href="https://github.com/sn0rlaxlife"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-secondary"
      >
        GitHub →
      </a>
    </div>
  </div>
</section>

<style>
:root {
    --bg: #09090b;
    --text: #f8fafc;
    --muted: #94a3b8;

    --primary: #2563eb;
    --secondary: #3b82f6;
}

.hero {
    min-height: 85vh;

    display: flex;
    align-items: center;
    justify-content: center;

    padding: 4rem 2rem;

    background:
        radial-gradient(circle at top right,
        rgba(37,99,235,.20),
        transparent 45%),
        var(--bg);
}

.hero__content{
    max-width:900px;
}

.hero__eyebrow{
    color:var(--secondary);

    text-transform:uppercase;

    letter-spacing:.15em;

    font-size:.8rem;

    font-weight:600;
}

h1{

    margin-top:1rem;

    font-size:clamp(3rem,8vw,5.5rem);

    line-height:1.05;

    font-weight:800;

    color:var(--text);
}

.gradient{

    background:linear-gradient(
        90deg,
        #2563eb,
        #60a5fa
    );

    -webkit-background-clip:text;

    color:transparent;
}

.hero__description{

    margin-top:2rem;

    max-width:700px;

    font-size:1.2rem;

    line-height:1.8;

    color:var(--muted);
}

.hero__actions{

    margin-top:3rem;

    display:flex;

    gap:1rem;

    flex-wrap:wrap;
}

.btn{

    padding:.9rem 1.6rem;

    border-radius:10px;

    text-decoration:none;

    transition:.25s;
}

.btn-primary{

    background:#2563eb;

    color:white;
}

.btn-primary:hover{

    background:#3b82f6;
}

.btn-secondary{

    border:1px solid #334155;

    color:white;
}

.btn-secondary:hover{

    border-color:#2563eb;

    background:#111827;
}
</style>
